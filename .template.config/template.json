{
  "$schema": "http://json.schemastore.org/template",
  "author": "pobochniy",
  "classifications": ["Web", "API", "Angular"],
  "name": "Pet Project Template",
  "description": "Full-stack template: ASP.NET Core API + Angular frontend",
  "identity": "pobochniy.PetTemplate",
  "version": "1.0.0",
  "shortName": "pet",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "PetTemplate",
  "preferNameDirectory": true,
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            ".git/**",
            ".idea/**",
            "**/bin/**",
            "**/obj/**",
            "**/.DS_Store",
            "PetTemplate.Web/web/node_modules/**",
            "PetTemplate.Web/web/.angular/**",
            "PetTemplate.Web/web/dist/**",
            ".template.config/**"
          ]
        }
      ]
    }
  ]
}
